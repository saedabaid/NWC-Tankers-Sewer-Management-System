<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- <title>@ViewBag.Title - My ASP.NET Application </title> -->
  <title>@ViewBag.Title </title>
  <base href="/" />
  <style>
    #toastr-container > div {
      width: auto !important;
      min-width: 345px;
    }

    .toastr-messages-en {
      text-align: left;
      line-height: 25px !important;
      text-transform: none;
    }

    .toastr-messages-ar {
      text-align: right;
      line-height: 25px !important;
      text-transform: none;
    }

    .text-original {
      text-transform: none;
    }
  </style>
  @Styles.Render("~/Content/css")
  @Scripts.Render("~/bundles/modernizr")

  <link href="~/Content/bootstrap.css" rel="stylesheet" />
  <link href="~/Content/Site.css" rel="stylesheet" />

  @{ if (System.Configuration.ConfigurationManager.AppSettings["TMS"] == "true")
    {
      <!-- Production -->
      @*<link rel="stylesheet" href="dist/styles.a0181ddddf627510300f.css">*@


      <link rel="stylesheet" type="text/css" href="/assets/TMSBranding/styles/css/component.css">
      <link rel="stylesheet" type="text/css" href="/assets/TMSBranding/styles/css/Branding_en.css">
      <link rel="stylesheet" type="text/css" href="/assets/TMSBranding/styles/css/font-awesome.min.css">
      <script type="text/javascript" src="/assets/TMSBranding/styles/js/classie.js"></script>
      <script type="text/javascript" src="/assets/TMSBranding/styles/js/mlpushmenu.js"></script>


    }
    else
    {

      <link rel="stylesheet" type="text/css" href="/assets/fmsBranding/styles/css/component.css">
      <link rel="stylesheet" type="text/css" href="/assets/fmsBranding/styles/css/Branding_en.css">
      <link rel="stylesheet" type="text/css" href="/assets/fmsBranding/styles/css/font-awesome.min.css">
      <script type="text/javascript" src="/assets/fmsBranding/styles/js/classie.js"></script>
      <script type="text/javascript" src="/assets/fmsBranding/styles/js/mlpushmenu.js"></script>

    }

  }

  <link rel="icon" type="image/x-icon" href="@System.Configuration.ConfigurationManager.AppSettings["favicon"] ">


</head>
<body>
  @*<div class="navbar navbar-inverse navbar-fixed-top">
