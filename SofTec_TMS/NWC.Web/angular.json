{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "NewNWC": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {
        "@schematics/angular:component": {
          "styleext": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "deployUrl": "/",
            "outputPath": "dist",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "src/tsconfig.app.json",
            "extractCss": true,
            "assets": [
              "src/favicon.ico",
              "src/web.config",
              "src/assets"
            ],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "./src/assets/css/bootstrap_3-4-1/scss/_bootstrap.scss",
              "./node_modules/angular-tree-component/dist/angular-tree-component.css",
              "./node_modules/bootstrap/scss/bootstrap.scss",
              "./src/assets/css/common.scss",
              "./src/assets/TMSBranding/styles/sass/component.scss",
              "./src/assets/fmsBranding/styles/css/branding_ar.css",
              "./src/assets/TMSBranding/styles/sass/common.scss",
              "./src/assets/fmsBranding/styles/sass/fontawesome/fontawesome.scss",
              "./src/assets/fmsBranding/styles/sass/fontawesome/regular.scss",
              "./src/assets/fmsBranding/styles/sass/fontawesome/solid.scss",
              "./src/assets/fmsBranding/styles/sass/fontawesome/brands.scss",
              {
                "input": "./src/assets/fmsBranding/styles/css/branding_ar.css",
                "bundleName": "arabicStyle",
                "lazy": true
              },
              {
                "input": "./src/assets/fmsBranding/styles/css/branding_en.css",
                "bundleName": "englishStyle",
                "lazy": true
              }
            ],
            "scripts": [
              "./node_modules/jquery/dist/jquery.min.js",
              "./node_modules/bootstrap/dist/js/bootstrap.min.js",
              "./src/assets/fmsBranding/styles/js/classie.js",
              "./src/assets/fmsBranding/styles/js/mlpushmenu.js"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "NewNWC:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "NewNWC:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "NewNWC:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "src/test.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "src/tsconfig.spec.json",
            "karmaConfig": "src/karma.conf.js",
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "src/styles.css"
            ],
            "scripts": [],
            "assets": [
              "src/favicon.ico",
              "src/web.config",
              "src/assets"
            ]
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "src/tsconfig.app.json",
              "src/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "NewNWC-e2e": {
      "root": "e2e/",
      "projectType": "application",
      "architect": {
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "e2e/protractor.conf.js",
            "devServerTarget": "NewNWC:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "NewNWC:serve:production"
            }
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": "e2e/tsconfig.e2e.json",
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    }
  },
  "defaultProject": "NewNWC",
  "cli": {
    "analytics": "9824d3cb-ce15-4962-9703-e33b39cd180a"
  }
}