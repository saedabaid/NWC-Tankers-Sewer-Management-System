  <system.serviceModel>
    <bindings>
      <customBinding>
        <binding name="echannelGetLocationInfoBinding">
          <textMessageEncoding messageVersion="Soap11" writeEncoding="utf-8" />
          <httpTransport />
        </binding>
      </customBinding>
    </bindings>
    <client>      
